# MedSecure Environment Configuration

# ================================
# Database
# ================================
MONGODB_URI=mongodb://localhost:27017/medsecure

# ================================
# JWT / Auth
# ================================
JWT_SECRET=your-very-secure-jwt-secret-change-this-in-production
JWT_EXPIRE=7d
USE_HTTPS=true

# ================================
# Frontend URL (for CORS)
# ================================
FRONTEND_URL=https://localhost:5173

# ================================
# Backend Server
# ================================
PORT=5000
NODE_ENV=development

# ================================
# IPFS / Pinata (optional)
# ================================
PINATA_JWT=
PINATA_API_URL=https://api.pinata.cloud
IPFS_API_URL=https://ipfs.infura.io:5001
IPFS_PROJECT_ID=
IPFS_PROJECT_SECRET=

# ================================
# Nginx SSL Paths (optional)
# ================================
# SSL_CERT_PATH=./nginx/ssl/medsecure.crt
# SSL_KEY_PATH=./nginx/ssl/medsecure.key
